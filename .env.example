# Exchange: bybit or binance
EXCHANGE=bybit
API_KEY=your_api_key
API_SECRET=your_api_secret

# Mode: paper (testnet) or live
MODE=paper

# Trading
SYMBOL=BTC/USDT
TIMEFRAME=1h
LEVERAGE=3

# Risk
RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.04
MAX_POSITION_PCT=0.20

# Funding rate arbitrage
FUNDING_ARB=true
